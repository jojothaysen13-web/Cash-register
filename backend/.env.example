PORT=4000
JWT_SECRET=change-this-secret-in-production
JWT_EXPIRES_IN=8h

DB_FILE=./data/cash-register.db

# Optional: if redis is unreachable the app falls back to direct DB reads
REDIS_URL=redis://127.0.0.1:6379

# Optional: leave empty to use deterministic mock card payments
STRIPE_SECRET_KEY=

CORS_ORIGIN=http://localhost:5173
